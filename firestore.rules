rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userRole(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data.role;
    }

    function isSelf(uid) {
      return request.auth.uid == uid;
    }

    function isLawyerOrAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && (userRole(request.auth.uid) == 'lawyer' || userRole(request.auth.uid) == 'admin');
    }

    function isSafeText(v, max) {
      return v is string && v.size() <= max && v.size() >= 1;
    }

    function isSafeProfile(profile) {
      return isSafeText(profile.uid, 128)
        && profile.uid is string
        && isSelf(profile.uid)
        && profile.displayName is string
        && profile.displayName.size() <= 80
        && profile.email is string
        && profile.role in ['member', 'pendingLawyer', 'lawyer', 'admin']
        && profile.createdAt is timestamp
        && profile.updatedAt is timestamp
        && profile.deleted is bool;
    }

    function isValidConsultation(payload) {
      return isSafeText(payload.topic, 120)
        && payload.area in ['contracts', 'workplace', 'smallBusiness', 'cyber', 'other']
        && payload.urgency in ['low', 'normal', 'high', 'critical']
        && isSafeText(payload.notes, 5000)
        && payload.createdBy is string
        && payload.clientName is string
        && payload.clientName.size() <= 80
        && isSafeText(payload.preferredContact, 80)
        && payload.createdAt is timestamp
        && payload.updatedAt is timestamp
        && payload.status in ['open', 'closed']
        && payload.deleted is bool;
    }

    function isValidReport(payload) {
      return isSafeText(payload.title, 120)
        && payload.category in ['fraud', 'harassment', 'discrimination', 'stolenBusinessData', 'other']
        && (!('businessName' in payload) || (payload.businessName is string && payload.businessName.size() <= 80))
        && (!('location' in payload) || (payload.location is string && payload.location.size() <= 80))
        && isSafeText(payload.body, 5000)
        && payload.reportedBy is string
        && payload.reporterAlias is string
        && payload.reporterAlias.size() <= 80
        && payload.occurredAt is timestamp
        && payload.createdAt is timestamp
        && payload.anonymous is bool
        && payload.priority in ['low', 'medium', 'high']
        && payload.status in ['open', 'reviewing', 'resolved']
        && payload.deleted is bool
        && (!('hasAttachment' in payload) || payload.hasAttachment is bool)
        && (!('attachmentUrl' in payload) || payload.attachmentUrl is string)
        && (!('attachmentPath' in payload) || payload.attachmentPath is string);
    }

    function isValidPost(payload) {
      return isSafeText(payload.title, 160)
        && isSafeText(payload.body, 5000)
        && payload.createdBy is string
        && payload.authorName is string
        && payload.authorName.size() <= 80
        && payload.flags is int
        && payload.flags >= 0
        && payload.removed is bool
        && payload.createdAt is timestamp
        && payload.updatedAt is timestamp;
    }

    function isValidComment(payload) {
      return isSafeText(payload.body, 800)
        && payload.postId is string
        && payload.createdBy is string
        && payload.authorName is string
        && payload.authorName.size() <= 80
        && payload.createdAt is timestamp
        && payload.deleted is bool;
    }

    match /users/{uid} {
      allow read: if signedIn() && (isSelf(uid) || isLawyerOrAdmin());
      allow create: if signedIn()
        && isSelf(uid)
        && isSafeProfile(request.resource.data)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.role in ['member', 'pendingLawyer']
        && request.resource.data.deleted == false;
      allow update: if signedIn()
        && (
          (isSelf(uid) && request.resource.data.role == resource.data.role && isSafeProfile(request.resource.data))
          || isLawyerOrAdmin()
        );
      allow delete: if false;
    }

    match /consultations/{consultId} {
      allow create: if signedIn()
        && request.resource.data.createdBy == request.auth.uid
        && isValidConsultation(request.resource.data);
      allow read: if signedIn() && (
        resource.data.createdBy == request.auth.uid || isLawyerOrAdmin()
      );
      allow update: if signedIn() && (
        isValidConsultation(request.resource.data)
        && (resource.data.createdBy == request.auth.uid || isLawyerOrAdmin())
      );
      allow delete: if false;
    }

    match /incidentReports/{reportId} {
      allow create: if signedIn()
        && request.resource.data.reportedBy == request.auth.uid
        && isValidReport(request.resource.data);
      allow read: if signedIn() && (
        resource.data.reportedBy == request.auth.uid || isLawyerOrAdmin()
      );
      allow update: if signedIn() && (
        isValidReport(request.resource.data)
        && (resource.data.reportedBy == request.auth.uid || isLawyerOrAdmin())
      );
      allow delete: if false;
    }

    match /communityPosts/{postId} {
      allow create: if signedIn()
        && request.resource.data.createdBy == request.auth.uid
        && isValidPost(request.resource.data);
      allow read: if signedIn() && (
        !resource.data.removed || isLawyerOrAdmin()
      );
      allow update: if signedIn() && (
        isValidPost(request.resource.data)
        && (resource.data.createdBy == request.auth.uid || isLawyerOrAdmin())
      );
      allow delete: if false;
    }

    match /communityComments/{commentId} {
      allow create: if signedIn()
        && request.resource.data.createdBy == request.auth.uid
        && isValidComment(request.resource.data);
      allow read: if signedIn() && (
        !resource.data.deleted || isLawyerOrAdmin()
      );
      allow update: if signedIn() && (
        isValidComment(request.resource.data)
        && (resource.data.createdBy == request.auth.uid || isLawyerOrAdmin())
      );
      allow delete: if false;
    }

    match /deletionRequests/{requestId} {
      allow create: if signedIn()
        && request.resource.data.requesterId == request.auth.uid
        && request.resource.data.requesterAlias is string
        && request.resource.data.requesterAlias.size() <= 80
        && request.resource.data.requesterEmail is string
        && request.resource.data.requesterEmail.size() <= 160
        && request.resource.data.reason is string
        && request.resource.data.reason.size() <= 1200
        && request.resource.data.reason.size() >= 1
        && request.resource.data.status == 'pending'
        && request.resource.data.requestedAt is timestamp
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.updatedBy == request.auth.uid;
      allow read: if isLawyerOrAdmin() || isSelf(resource.data.requesterId);
      allow update: if isLawyerOrAdmin()
        && request.resource.data.status in ['pending', 'approved', 'rejected']
        && request.resource.data.requesterId is string
        && request.resource.data.requestedAt is timestamp
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.updatedBy == request.auth.uid
        && request.resource.data.reviewedAt is timestamp
        && request.resource.data.reviewedBy == request.auth.uid;
      allow delete: if false;
    }
  }
}
