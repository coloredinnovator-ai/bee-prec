{
  "project": "BEE-CO-OP",
  "version": "1.0.0",
  "designTokens": {
    "primary": "amber-600",
    "background": "stone-50",
    "text": "stone-900",
    "accent": "amber-500"
  },
  "firestoreSchema": {
    "users": {
      "description": "Co-op members, board members, and maintenance staff",
      "fields": {
        "uid": "string",
        "displayName": "string",
        "email": "string",
        "role": "enum['member', 'board', 'maintenance']",
        "unitId": "string (optional)",
        "createdAt": "timestamp"
      }
    },
    "units": {
      "description": "Housing units directory",
      "fields": {
        "id": "string",
        "number": "string",
        "occupantId": "string (reference to users)",
        "status": "enum['occupied', 'vacant', 'maintenance']"
      }
    },
    "maintenance_tickets": {
      "description": "Maintenance requests",
      "fields": {
        "id": "string",
        "title": "string",
        "description": "string",
        "unitId": "string",
        "reportedBy": "string (reference to users)",
        "status": "enum['open', 'in-progress', 'resolved']",
        "createdAt": "timestamp"
      }
    },
    "meeting_minutes": {
      "description": "Real-time meeting minutes",
      "fields": {
        "id": "string",
        "title": "string",
        "content": "string",
        "date": "timestamp",
        "recordedBy": "string (reference to users)"
      }
    }
  }
}
